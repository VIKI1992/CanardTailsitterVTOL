    SetParmVal( canard_id, "Dihedral", "XSec_1", 0.000000 );
    SetParmVal( canard_id, "Twist", "XSec_1", 0.000000 );
    SetParmVal( canard_id, "SectTess_U", "XSec_1", 12 );
    Update();
    string elevon_ss = AddSubSurf( wing_id, SS_CONTROL, 0 );
    Update();
    SetParmVal( wing_id, "EtaStart", "SS_Control_1", 0.250000 );
    SetParmVal( wing_id, "EtaEnd", "SS_Control_1", 0.479167 );
    SetParmVal( wing_id, "UStart", "SS_Control_1", 0.760000 );
    SetParmVal( wing_id, "UEnd", "SS_Control_1", 1.0 );
    SetParmVal( wing_id, "SE_Const_Flag", "SS_Control_1", 1.0 );
    Update();
    int elevon_sym_group = CreateVSPAEROControlSurfaceGroup();
    SetVSPAEROControlGroupName( "ElevonSymmetric", elevon_sym_group );
    array<int> elevon_indices;
    elevon_indices.push_back( 1 );
    elevon_indices.push_back( 2 );
    AddSelectedToCSGroup( elevon_indices, elevon_sym_group );
    string cs_group_container_id = FindContainer( "VSPAEROSettings", 0 );
    SetParmVal( FindParm( cs_group_container_id, "Surf_" + elevon_ss + "_0_Gain", "ControlSurfaceGroup_0" ), 1 );
    SetParmVal( FindParm( cs_group_container_id, "Surf_" + elevon_ss + "_1_Gain", "ControlSurfaceGroup_0" ), 1 );
    int elevon_diff_group = CreateVSPAEROControlSurfaceGroup();
    SetVSPAEROControlGroupName( "ElevonDifferential", elevon_diff_group );
    AddSelectedToCSGroup( elevon_indices, elevon_diff_group );
    SetParmVal( FindParm( cs_group_container_id, "Surf_" + elevon_ss + "_0_Gain", "ControlSurfaceGroup_1" ), 1 );
    SetParmVal( FindParm( cs_group_container_id, "Surf_" + elevon_ss + "_1_Gain", "ControlSurfaceGroup_1" ), -1 );
    Update();
    string fuselage_id = AddGeom( "FUSELAGE", "" );
    SetGeomName( fuselage_id, "Fuselage" );
    SetParmVal( fuselage_id, "X_Rel_Location", "XForm", -0.550000 );
    SetParmVal( fuselage_id, "Length", "Design", 1.030000 );
    SetParmVal( fuselage_id, "Tess_W", "Shape", 49 );
    InsertXSec( fuselage_id, 1, XS_ELLIPSE );
    InsertXSec( fuselage_id, 1, XS_ELLIPSE );
    InsertXSec( fuselage_id, 1, XS_ELLIPSE );
    Update();
    string fuselage_id_xsec_surf = GetXSecSurf( fuselage_id, 0 );
    ChangeXSecShape( fuselage_id_xsec_surf, 0, XS_POINT );
    ChangeXSecShape( fuselage_id_xsec_surf, 1, XS_ELLIPSE );
    ChangeXSecShape( fuselage_id_xsec_surf, 2, XS_ELLIPSE );
    ChangeXSecShape( fuselage_id_xsec_surf, 3, XS_ELLIPSE );
    ChangeXSecShape( fuselage_id_xsec_surf, 4, XS_ELLIPSE );
    ChangeXSecShape( fuselage_id_xsec_surf, 5, XS_ELLIPSE );
    ChangeXSecShape( fuselage_id_xsec_surf, 6, XS_ELLIPSE );
    ChangeXSecShape( fuselage_id_xsec_surf, 7, XS_POINT );
    Update();
    string xsec_fuselage_id_0 = GetXSec( fuselage_id_xsec_surf, 0 );
    SetXSecContinuity( xsec_fuselage_id_0, 1 );
    SetXSecTanAngles( xsec_fuselage_id_0, XSEC_BOTH_SIDES, 0, 0, 0, 0 );
    SetXSecTanStrengths( xsec_fuselage_id_0, XSEC_BOTH_SIDES, 0.5, 0.5, 0.5, 0.5 );
    string xsec_fuselage_id_1 = GetXSec( fuselage_id_xsec_surf, 1 );
    SetParmVal( fuselage_id, "XLocPercent", "XSec_1", 0.077670 );
    SetParmVal( fuselage_id, "ZLocPercent", "XSec_1", 0.0 );
    SetParmVal( fuselage_id, "Ellipse_Width", "XSecCurve_1", 0.055000 );
    SetParmVal( fuselage_id, "Ellipse_Height", "XSecCurve_1", 0.065000 );
    SetXSecContinuity( xsec_fuselage_id_1, 1 );
    SetXSecTanAngles( xsec_fuselage_id_1, XSEC_BOTH_SIDES, 0, 0, 0, 0 );
    SetXSecTanStrengths( xsec_fuselage_id_1, XSEC_BOTH_SIDES, 0.5, 0.5, 0.5, 0.5 );
    string xsec_fuselage_id_2 = GetXSec( fuselage_id_xsec_surf, 2 );
    SetParmVal( fuselage_id, "XLocPercent", "XSec_2", 0.242718 );
    SetParmVal( fuselage_id, "ZLocPercent", "XSec_2", 0.0 );
    SetParmVal( fuselage_id, "Ellipse_Width", "XSecCurve_2", 0.120000 );
    SetParmVal( fuselage_id, "Ellipse_Height", "XSecCurve_2", 0.130000 );
    SetXSecContinuity( xsec_fuselage_id_2, 1 );
    SetXSecTanAngles( xsec_fuselage_id_2, XSEC_BOTH_SIDES, 0, 0, 0, 0 );
    SetXSecTanStrengths( xsec_fuselage_id_2, XSEC_BOTH_SIDES, 0.5, 0.5, 0.5, 0.5 );
    string xsec_fuselage_id_3 = GetXSec( fuselage_id_xsec_surf, 3 );
    SetParmVal( fuselage_id, "XLocPercent", "XSec_3", 0.456311 );
    SetParmVal( fuselage_id, "ZLocPercent", "XSec_3", 0.0 );
    SetParmVal( fuselage_id, "Ellipse_Width", "XSecCurve_3", 0.150000 );
    SetParmVal( fuselage_id, "Ellipse_Height", "XSecCurve_3", 0.145000 );
    SetXSecContinuity( xsec_fuselage_id_3, 1 );
    SetXSecTanAngles( xsec_fuselage_id_3, XSEC_BOTH_SIDES, 0, 0, 0, 0 );
    SetXSecTanStrengths( xsec_fuselage_id_3, XSEC_BOTH_SIDES, 0.5, 0.5, 0.5, 0.5 );
    string xsec_fuselage_id_4 = GetXSec( fuselage_id_xsec_surf, 4 );
    SetParmVal( fuselage_id, "XLocPercent", "XSec_4", 0.592233 );
    SetParmVal( fuselage_id, "ZLocPercent", "XSec_4", 0.0 );
    SetParmVal( fuselage_id, "Ellipse_Width", "XSecCurve_4", 0.155000 );
    SetParmVal( fuselage_id, "Ellipse_Height", "XSecCurve_4", 0.150000 );
    SetXSecContinuity( xsec_fuselage_id_4, 1 );
    SetXSecTanAngles( xsec_fuselage_id_4, XSEC_BOTH_SIDES, 0, 0, 0, 0 );
    SetXSecTanStrengths( xsec_fuselage_id_4, XSEC_BOTH_SIDES, 0.5, 0.5, 0.5, 0.5 );
    string xsec_fuselage_id_5 = GetXSec( fuselage_id_xsec_surf, 5 );
    SetParmVal( fuselage_id, "XLocPercent", "XSec_5", 0.728155 );
    SetParmVal( fuselage_id, "ZLocPercent", "XSec_5", 0.0 );
    SetParmVal( fuselage_id, "Ellipse_Width", "XSecCurve_5", 0.130000 );
    SetParmVal( fuselage_id, "Ellipse_Height", "XSecCurve_5", 0.125000 );
    SetXSecContinuity( xsec_fuselage_id_5, 1 );
    SetXSecTanAngles( xsec_fuselage_id_5, XSEC_BOTH_SIDES, 0, 0, 0, 0 );
    SetXSecTanStrengths( xsec_fuselage_id_5, XSEC_BOTH_SIDES, 0.5, 0.5, 0.5, 0.5 );
    string xsec_fuselage_id_6 = GetXSec( fuselage_id_xsec_surf, 6 );
    SetParmVal( fuselage_id, "XLocPercent", "XSec_6", 0.883495 );
    SetParmVal( fuselage_id, "ZLocPercent", "XSec_6", 0.0 );
    SetParmVal( fuselage_id, "Ellipse_Width", "XSecCurve_6", 0.070000 );
    SetParmVal( fuselage_id, "Ellipse_Height", "XSecCurve_6", 0.070000 );
    SetXSecContinuity( xsec_fuselage_id_6, 1 );
    SetXSecTanAngles( xsec_fuselage_id_6, XSEC_BOTH_SIDES, 0, 0, 0, 0 );
    SetXSecTanStrengths( xsec_fuselage_id_6, XSEC_BOTH_SIDES, 0.5, 0.5, 0.5, 0.5 );
