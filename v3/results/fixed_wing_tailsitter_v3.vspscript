    SetParmVal( wing_id, "Span", "XSec_1", 0.350000 );
    SetParmVal( wing_id, "Root_Chord", "XSec_1", 0.296000 );
    SetParmVal( wing_id, "Tip_Chord", "XSec_1", 0.244000 );
