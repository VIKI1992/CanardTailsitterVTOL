    SetParmVal( wing_id, "Dihedral", "XSec_4", 78.690068 );
    SetParmVal( wing_id, "Twist", "XSec_4", -1.500000 );
    SetParmVal( wing_id, "SectTess_U", "XSec_4", 12 );
    Update();
    string canard_id = AddGeom( "WING", "" );
    SetGeomName( canard_id, "Canard" );
    SetParmVal( canard_id, "X_Rel_Location", "XForm", -0.500000 );
    SetParmVal( canard_id, "Y_Rel_Location", "XForm", 0.000000 );
    SetParmVal( canard_id, "Z_Rel_Location", "XForm", 0.035000 );
    SetParmVal( canard_id, "Y_Rel_Rotation", "XForm", 2.000000 );
    SetParmVal( canard_id, "RotateAirfoilMatchDideralFlag", "WingGeom", 1.0 );
