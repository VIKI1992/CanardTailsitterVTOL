    SetXSecTanAngles( xsec_fuselage_id_7, XSEC_BOTH_SIDES, 0, 0, 0, 0 );
    SetXSecTanStrengths( xsec_fuselage_id_7, XSEC_BOTH_SIDES, 0.5, 0.5, 0.5, 0.5 );
    SetXSecTanAngles( xsec_fuselage_id_0, XSEC_BOTH_SIDES, 90, 90, 90, 90 );
    SetXSecTanAngles( xsec_fuselage_id_7, XSEC_BOTH_SIDES, -90, -90, -90, -90 );
    Update();
    string leftpropdisk = AddGeom( "PROP", "" );
    SetGeomName( leftpropdisk, "LeftPropDisk" );
    SetParmVal( leftpropdisk, "PropMode", "Design", PROP_DISK );
    SetParmVal( leftpropdisk, "Diameter", "Design", 0.533000 );
    SetParmVal( leftpropdisk, "X_Rel_Location", "XForm", 0.100000 );
    SetParmVal( leftpropdisk, "Y_Rel_Location", "XForm", 0.625000 );
    SetParmVal( leftpropdisk, "Z_Rel_Location", "XForm", 0.040000 );
    SetParmVal( leftpropdisk, "ReverseFlag", "Design", 0 );
    string rightpropdisk = AddGeom( "PROP", "" );
    SetGeomName( rightpropdisk, "RightPropDisk" );
    SetParmVal( rightpropdisk, "PropMode", "Design", PROP_DISK );
    SetParmVal( rightpropdisk, "Diameter", "Design", 0.533000 );
    SetParmVal( rightpropdisk, "X_Rel_Location", "XForm", 0.100000 );
    SetParmVal( rightpropdisk, "Y_Rel_Location", "XForm", -0.625000 );
    SetParmVal( rightpropdisk, "Z_Rel_Location", "XForm", 0.040000 );
    SetParmVal( rightpropdisk, "ReverseFlag", "Design", 1 );
    Update();
    WriteVSPFile( "v3/results/fixed_wing_tailsitter_v3.vsp3", SET_ALL );
