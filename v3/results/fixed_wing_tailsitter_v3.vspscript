void main()
{
    string wing_id = AddGeom( "WING", "" );
    SetGeomName( wing_id, "MainWing" );
    SetParmVal( wing_id, "X_Rel_Location", "XForm", -0.100000 );
    SetParmVal( wing_id, "Y_Rel_Location", "XForm", 0.000000 );
    SetParmVal( wing_id, "Z_Rel_Location", "XForm", 0.000000 );
    SetParmVal( wing_id, "Y_Rel_Rotation", "XForm", 1.500000 );
    SetParmVal( wing_id, "RotateAirfoilMatchDideralFlag", "WingGeom", 1.0 );
    SetParmVal( wing_id, "Sym_Planar_Flag", "Sym", 2 );
    InsertXSec( wing_id, 1, XS_FOUR_SERIES );
    InsertXSec( wing_id, 2, XS_FOUR_SERIES );
    InsertXSec( wing_id, 3, XS_FOUR_SERIES );
    Update();
    string wing_id_xsec_surf = GetXSecSurf( wing_id, 0 );
    string xsec_wing_id_0 = GetXSec( wing_id_xsec_surf, 0 );
    ChangeXSecShape( wing_id_xsec_surf, 0, XS_FILE_AIRFOIL );
    Update();
    xsec_wing_id_0 = GetXSec( wing_id_xsec_surf, 0 );
    ReadFileAirfoil( xsec_wing_id_0, "airfoils/sd7037.dat" );
    string xsec_wing_id_1 = GetXSec( wing_id_xsec_surf, 1 );
    ChangeXSecShape( wing_id_xsec_surf, 1, XS_FILE_AIRFOIL );
    Update();
    xsec_wing_id_1 = GetXSec( wing_id_xsec_surf, 1 );
    ReadFileAirfoil( xsec_wing_id_1, "airfoils/sd7037.dat" );
    string xsec_wing_id_2 = GetXSec( wing_id_xsec_surf, 2 );
    ChangeXSecShape( wing_id_xsec_surf, 2, XS_FILE_AIRFOIL );
    Update();
    xsec_wing_id_2 = GetXSec( wing_id_xsec_surf, 2 );
