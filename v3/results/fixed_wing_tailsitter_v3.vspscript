    SetParmVal( wing_id, "Twist", "XSec_3", -1.500000 );
    SetParmVal( wing_id, "SectTess_U", "XSec_3", 12 );
    SetDriverGroup( wing_id, 4, SPAN_WSECT_DRIVER, ROOTC_WSECT_DRIVER, TIPC_WSECT_DRIVER );
    SetParmVal( wing_id, "Span", "XSec_4", 0.127475 );
    SetParmVal( wing_id, "Root_Chord", "XSec_4", 0.128000 );
    SetParmVal( wing_id, "Tip_Chord", "XSec_4", 0.100000 );
    SetParmVal( wing_id, "Sweep", "XSec_4", 34.215702 );
